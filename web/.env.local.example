# === Supabase ===
# 앱이 실제로 쓰는 건 아래 두 개뿐입니다.
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role(비밀) 키 — RLS를 무시하는 마스터키.
# scripts/seed.mjs 로 초기 데이터를 넣을 때만 잠깐 필요하고, 앱 코드에서는 쓰지 않습니다.
# 시드가 끝나면 비워두세요.
SUPABASE_SERVICE_ROLE_KEY=

# === 알라딘 Open API (서버 전용 — 절대 클라이언트에 노출 금지) ===
ALADIN_TTB_KEY=your-ttb-key

# === 데모 계정 (시드 전용) ===
# 이제 앱은 실제 구글 로그인을 사용하므로 런타임에는 필요 없습니다.
# scripts/seed.mjs 가 샘플 데이터를 넣을 때만 쓰이며, 처음 실행 시 자동 생성되어 여기에 기록됩니다.
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=auto-generated-by-seed
