# 의존성 / 빌드 산출물 (어느 폴더에 있든 제외)
node_modules/
.next/
out/
build/
dist/

# 환경변수 — 비밀키가 들어있으므로 절대 커밋 금지
.env
.env.*
# 예시 파일은 비밀값이 없으므로 커밋한다
!.env*.example

# 로컬 도구 설정 (하위 폴더에 있는 것까지 모두)
**/.claude/
**/.vercel/

# OS / 에디터
Thumbs.db
.DS_Store
*.swp
.idea/
.vscode/

# 로그
*.log
npm-debug.log*
yarn-error.log*
